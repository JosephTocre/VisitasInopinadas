generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  INSPECTOR
}

model Usuario {
  id_usuario Int @id @default(autoincrement())

  nombre     String
  apellidos  String
  correo     String @unique
  contrasena String
  rol        Rol

  visitas HechoVisita[]
}

model HechoVisita {
  id_visita Int @id @default(autoincrement())

  sede            String
  lugar           String
  curso           String
  campo_formativo String

  fecha                DateTime
  turno                String
  hora_practica_teoria String
  n_semana             Int
  hora_inicio          DateTime
  hora_termino         DateTime
  ciclo                String

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id_usuario])

  @@index([fecha])
  @@index([usuarioId])

  controlDocente    ControlDocente?
  controlMaterial   ControlMaterial?
  controlSilabo     ControlSilabo?
  controlEstudiante ControlEstudiante?
  controlGuia       ControlGuia?
}

model ControlDocente {
  id_control_docente Int @id @default(autoincrement())

  nombre_docente     String
  apellido_docente   String
  actividad          String
  presente           Boolean
  horario_programado Boolean
  interaccion        Boolean
  observaciones      String?

  visitaId Int @unique
  visita   HechoVisita @relation(fields: [visitaId], references: [id_visita])
}

model ControlMaterial {
  id_control_material Int @id @default(autoincrement())

  cumple        Boolean
  observaciones String?

  visitaId Int @unique
  visita   HechoVisita @relation(fields: [visitaId], references: [id_visita])
}

model ControlSilabo {
  id_control_silabo Int @id @default(autoincrement())

  coincidencia_actual   Boolean
  coincidencia_anterior Boolean
  ingreso_avance        Boolean
  observaciones         String?

  visitaId Int @unique
  visita   HechoVisita @relation(fields: [visitaId], references: [id_visita])
}

model ControlEstudiante {
  id_control_estudiante Int @id @default(autoincrement())

  control_ambiente       Boolean
  observaciones_ambiente String?

  control_intranet       Boolean
  observaciones_intranet String?

  observaciones String?

  visitaId Int @unique
  visita   HechoVisita @relation(fields: [visitaId], references: [id_visita])
}

enum EstadoCumplimiento {
  CUMPLE
  NO_CUMPLE
  NO_APLICA
}

model ControlGuia {
  id_control_guia Int @id @default(autoincrement())

  tema_programado EstadoCumplimiento
  logro           EstadoCumplimiento
  rubrica         EstadoCumplimiento
  observaciones   String?
  requerimientos  String?

  visitaId Int @unique
  visita   HechoVisita @relation(fields: [visitaId], references: [id_visita])
}